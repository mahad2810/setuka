# ─── MongoDB ──────────────────────────────────────────────────────────────────
MONGODB_URI=your_mongodb_uri_here

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=your_jwt_secret_here
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3000

# ─── Blockchain (Polygon Amoy Testnet) ────────────────────────────────────────
BLOCKCHAIN_PRIVATE_KEY=your_private_key_here
ALCHEMY_API_KEY=your_alchemy_api_key_here
TOURIST_CONTRACT_ADDRESS=your_contract_address_here
TOURIST_CONTRACT_NETWORK=amoy
USE_MOCK_BLOCKCHAIN=true

# ─── URLs ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ─── AI (Groq) ───────────────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─── SafetyScore API ─────────────────────────────────────────────────────────
SCORE_API_URL=https://safetyscore-regression.onrender.com

# ─── Twilio (SMS/Emergency) ──────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here
DEST_EMERGENCY_NUMBER=your_dest_emergency_number_here
POLICE_EMERGENCY_NUMBER=your_police_emergency_number_here

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here
